{
  "name": "ledger-api",
  "main": "src/index.ts",
  "observability": {
    "enabled": false,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": true,
      "persist": true,
      "head_sampling_rate": 1
    }
  },
  "routes": [
    "api.gpnet.dev/ledger/*"
  ],
  "compatibility_date": "2024-03-22",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "ledger-db",
      "database_id": "dfd7fa4a-91a4-42a6-be16-465491b0467a"
    }
  ],
  "r2_buckets": [
    {
      "binding": "ASSETS",
      "bucket_name": "ledger-prd-assets"
    }
  ],
  "vars": {
    "DISCORD_WEBHOOK_URL": "",
    "RESEND_API_KEY": "",
    "ENCRYPTION_KEY": "",
    "ENVIRONMENT": "development"
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "SESSION",
        "class_name": "HouseholdSession"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_classes": ["HouseholdSession"]
    }
  ],
  "triggers": {
    "crons": ["0 0 * * SUN"]
  },
  "migrations_dir": "../../packages/db/migrations"
}
