{
  "name": "ledger",
  "private": true,
  "workspaces": [
    "apps/*",
    "apps/microsoft-identity-association",
    "packages/*"
  ],
  "version": "3.16.1",
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "deploy:api": "npm run deploy -w apps/api",
    "deploy:web": "npm run deploy -w apps/web"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "wrangler": "^4.78.0"
  }
}
